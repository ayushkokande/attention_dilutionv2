   ],
   "source": [
    "# --- Phase 6 attribution: compute per-(layer, head) DLA onto V_refusal at the\n",
    "# last token, for a fixed prompt (or small N_ATTR=8 prompt average), across the\n",
    "# 2x2 (setting x N_short/N_long) grid.\n",
    "\n",
    "N_ATTR = 6                               # number of prompts to average over (small for memory)\n",
    "N_SHORT = 0\n",
    "N_LONG  = 2048                           # within MAX_ATTN_N; raise to 4096 only on 80GB\n",
    "attr_subset = HARMFUL_EVAL[:N_ATTR]\n",
    "\n",
    "\n",
    "def per_head_dla_at_last(prompt, hooks_for_setting=None):\n",
    "    \"\"\"Returns [n_layers, n_heads] of (per-head output at last position) . V_refusal.\"\"\"\n",
    "    model.reset_hooks()\n",
    "    model.set_use_attn_result(True)\n",
    "    text = format_prompt(prompt)\n",
    "    toks = model.to_tokens(text, prepend_bos=False)\n",
    "    if toks.shape[1] > model.cfg.n_ctx:\n",
    "        del toks; model.set_use_attn_result(False); return None\n",
    "    n_layers, n_heads = model.cfg.n_layers, model.cfg.n_heads\n",
    "    contrib = torch.zeros(n_layers, n_heads, dtype=torch.float32)\n",
    "    direction = V_REFUSAL.float().cpu()\n",
    "    try:\n",
    "        if hooks_for_setting:\n",
    "            with model.hooks(fwd_hooks=hooks_for_setting):\n",
    "                _, cache = model.run_with_cache(\n",
    "                    toks, names_filter=lambda n: n.endswith(\"attn.hook_result\"))\n",
    "        else:\n",
    "            _, cache = model.run_with_cache(\n",
    "                toks, names_filter=lambda n: n.endswith(\"attn.hook_result\"))\n",
    "        for l in range(n_layers):\n",
    "            key = f\"blocks.{l}.attn.hook_result\"\n",
    "            if key in cache:\n",
    "                per_head = cache[key][0, -1].float().cpu()  # [n_heads, d_model]\n",
    "                contrib[l] = per_head @ direction\n",
    "        del cache\n",
    "    finally:\n",
    "        model.reset_hooks(); model.set_use_attn_result(False)\n",
    "        del toks; gc.collect(); torch.cuda.empty_cache()\n",
    "    return contrib\n",
    "\n",
    "\n",
    "def per_source_token_attn_for_head(prompt, layer, head, hooks_for_setting=None):\n",
    "    \"\"\"Returns the attention pattern at the LAST query position for one head.\n",
    "    Shape: [seq_len]. Also returns the harmful-span (lo, hi).\"\"\"\n",
    "    model.reset_hooks()\n",
    "    span, _ = locate_harmful_span(prompt, prompt) if False else (None, None)\n",
    "    # We need the harmful request to locate the span; prompt here is already-diluted.\n",
    "    # The build_diluted_prompt path passes the harmful_req as the trailing slice — locate it again.\n",
    "    text = format_prompt(prompt)\n",
    "    toks = model.to_tokens(text, prepend_bos=False)\n",
    "    if toks.shape[1] > model.cfg.n_ctx:\n",
    "        del toks; return None\n",
    "    captured = [None]\n",
    "    def fn(pattern, hook):\n",
    "        captured[0] = pattern[0, head, -1].float().cpu().clone()\n",
    "        return None\n",
    "    try:\n",
    "        if hooks_for_setting:\n",
    "            all_hooks = list(hooks_for_setting) + [(f\"blocks.{layer}.attn.hook_pattern\", fn)]\n",
    "            with model.hooks(fwd_hooks=all_hooks):\n",
    "                _ = model(toks)\n",
    "        else:\n",
    "            with model.hooks(fwd_hooks=[(f\"blocks.{layer}.attn.hook_pattern\", fn)]):\n",
    "                _ = model(toks)\n",
    "    finally:\n",
    "        model.reset_hooks(); del toks; gc.collect(); torch.cuda.empty_cache()\n",
    "    return captured[0]   # [seq_len]\n",
    "\n",
    "\n",
    "# Precompute the 4 attribution heatmaps  (intact x N_short, intact x N_long, ablated x N_short, ablated x N_long)\n",
    "attribution_maps = {}                # (setting, N) -> [n_layers, n_heads] cpu tensor\n",
    "hooks_intact  = None\n",
    "hooks_ablated = make_ablation_hooks(V_REFUSAL, model.cfg.n_layers)\n",
    "\n",
    "for setting, hooks_set in [(\"intact\", hooks_intact), (\"ablated\", hooks_ablated)]:\n",
    "    for N in [N_SHORT, N_LONG]:\n",
    "        accum = None; n_used = 0\n",
    "        try:\n",
    "            for p in tqdm(attr_subset, desc=f\"DLA {setting} N={N}\"):\n",
    "                diluted, _ = build_diluted_prompt(p, N)\n",
    "                contrib = per_head_dla_at_last(diluted, hooks_for_setting=hooks_set)\n",
    "                if contrib is None: continue\n",
    "                accum = contrib if accum is None else accum + contrib\n",
    "                n_used += 1\n",
    "        except torch.cuda.OutOfMemoryError as e:\n",
    "            print(f\"  OOM at {setting}/N={N}: {e}\")\n",
    "            model.reset_hooks(); model.set_use_attn_result(False)\n",
    "            gc.collect(); torch.cuda.empty_cache()\n",
    "        attribution_maps[(setting, N)] = (accum/max(n_used,1)) if accum is not None else None\n",
    "        print(f\"  {setting} N={N}: averaged over n={n_used}\")\n",
    "\n",
    "\n",
    "# Save\n",
    "torch.save(attribution_maps, OUT/\"phase6_attribution_maps.pt\")\n",
    "print(\"Saved: phase6_attribution_maps.pt\")\n"
   ]
  },
