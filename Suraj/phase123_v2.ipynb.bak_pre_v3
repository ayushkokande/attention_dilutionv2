   "source": [
    "# --- Layer sweep using a SMALL eval (32 prompts) for speed, then verify on full eval.\n",
    "SWEEP_EVAL_N = 24  # 24 prompts on 40GB / Qwen3-8B is comfortable; raise to 32 on 80GB\n",
    "sweep_eval = HARMFUL_EVAL[:SWEEP_EVAL_N]\n",
    "\n",
    "# Search 35-90% depth (refusal direction usually mid-to-late on Qwen)\n",
    "n_layers = model.cfg.n_layers\n",
    "candidate_layers = list(range(int(n_layers*0.35), int(n_layers*0.90)+1, 2))   # step=2 keeps the sweep ~14 layers\n",
    "print(f\"candidate layers ({len(candidate_layers)}): {candidate_layers}\")\n",
    "\n",
    "sweep_records = []\n",
    "for l in tqdm(candidate_layers, desc=\"layer sweep\"):\n",
    "    direction = V_refusal_unit[l]\n",
    "    hooks = make_ablation_hooks(direction, n_layers)\n",
    "    rate_h, _ = measure_refusal_rate(model, sweep_eval, hooks=hooks)\n",
    "    rate_b, _ = measure_refusal_rate(model, HARMLESS_EVAL[:SWEEP_EVAL_N], hooks=hooks)\n",
    "    sweep_records.append({\n",
    "        \"layer\": l, \"harmful_refusal_post_ablate\": rate_h,\n",
    "        \"harmless_refusal_post_ablate\": rate_b,\n",
    "    })\n",
    "    print(f\"  L{l:02d}  harmful={rate_h:.2%}  harmless={rate_b:.2%}\")\n",
    "    torch.cuda.empty_cache()\n",
    "\n",
    "df_sweep = pd.DataFrame(sweep_records)\n",
    "df_sweep.to_csv(OUT/\"phase1_layer_sweep.csv\", index=False)\n",
    "# Best = lowest harmful refusal post-ablation, with harmless refusal kept in check (<=20%)\n",
    "ok_rows = df_sweep[df_sweep[\"harmless_refusal_post_ablate\"] <= 0.20]\n",
    "if len(ok_rows) == 0:\n",
    "    print(\"WARNING: every candidate also raised harmless-refusal — falling back to min(harmful_refusal)\")\n",
    "    ok_rows = df_sweep\n",
    "BEST_LAYER = int(ok_rows.sort_values(\"harmful_refusal_post_ablate\").iloc[0][\"layer\"])\n",
    "post_h = float(df_sweep.loc[df_sweep[\"layer\"]==BEST_LAYER, \"harmful_refusal_post_ablate\"].iloc[0])\n",
    "print(f\"\\n>>> BEST_LAYER = {BEST_LAYER}  (post-ablation harmful refusal on sweep = {post_h:.2%})\")\n",
    "\n",
    "V_REFUSAL = V_refusal_unit[BEST_LAYER].clone()\n",
    "torch.save({\n",
    "    \"V_refusal\": V_REFUSAL,\n",
    "    \"layer\": BEST_LAYER,\n",
    "    \"norm\": float(V_refusal_norms[BEST_LAYER]),\n",
    "    \"n_layers\": n_layers, \"d_model\": model.cfg.d_model,\n",
    "}, OUT/\"V_refusal.pt\")\n",
    "print(f\"Saved V_refusal.pt at layer {BEST_LAYER}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "73453798",
