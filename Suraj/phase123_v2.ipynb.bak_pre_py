    "if \"status\" not in df3.columns: df3[\"status\"] = \"ok\"\n",
    "ok3 = df3[df3[\"status\"]==\"ok\"]\n",
    "fig = go.Figure()\n",
    "for N in sorted(ok3[\"N\"].unique()):\n",
    "    sub = ok3[ok3[\"N\"]==N]\n",
    "    fig.add_trace(go.Scatter(x=sub[\"alpha\"], y=sub[\"refusal_rate\"],\n",
    "                             name=f\"N={int(N)}\", mode=\"lines+markers\"))\n",
    "fig.update_layout(\n",
