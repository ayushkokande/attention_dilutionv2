   "source": [
    "# --- Heatmap of per-head attribution to refusal\n",
    "fig = px.imshow(\n",
    "    head_attrib.numpy(),\n",
    "    labels=dict(x=\"Head\", y=\"Layer\", color=\"Proj. onto V_refusal\"),\n",
    "    color_continuous_scale=\"RdBu_r\", color_continuous_midpoint=0,\n",
    "    aspect=\"auto\",\n",
    "    title=f\"Per-head attribution to V_refusal ({MODEL_SLUG}, read layer L{BEST_LAYER})\",\n",
    ")\n",
    "fig.update_xaxes(dtick=2); fig.update_yaxes(dtick=2)\n",
    "fig.write_image(str(OUT/\"fig_phase1_heatmap.png\"), width=1100, height=720)\n",
    "fig.show()\n",
    "print(\"Phase 1 complete. Saved: V_refusal.pt, guardrail_heads.pt, phase1_*.csv, 2 figures.\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "914dc316",
   "metadata": {},
   "source": [
    "## Phase 2 — Context dilution scaling sweep\n",
    "\n",
    "For each N in `{0, 128, 512, 1k, 2k, 4k, 8k, 16k}`:\n",
    "- **H1**: mean attention mass that Guardrail Heads put on the harmful-request span (only N <= 4096 — full attention pattern OOMs above)\n",
    "- **H2**: cosine similarity of the residual at the last harmful token (layer BEST_LAYER) to V_refusal\n",
    "- **Behavior**: greedy refusal rate\n",
    "\n",
    "Two-pass per N (measurement, then generation), per-N OOM-tolerant.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "b9f08a14",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Resumed: V_refusal at L24; top guardrail head = (22, 7, 3.7682111263275146)\n"
     ]
    }
   ],
   "source": [
    "# --- Resume helper (safe to re-run after kernel restart)\n",
    "import torch, gc\n",
    "from pathlib import Path\n",
    "OUT = Path(\"./results_v2\")\n",
    "\n",
    "v = torch.load(OUT/\"V_refusal.pt\")\n",
    "V_REFUSAL  = v[\"V_refusal\"]\n",
    "BEST_LAYER = int(v[\"layer\"])\n",
    "\n",
    "g = torch.load(OUT/\"guardrail_heads.pt\")\n",
    "guardrail_heads = g[\"guardrail_heads\"]\n",
    "head_attrib     = g[\"head_attrib\"]\n",
    "\n",
    "model.reset_hooks()\n",
    "model.set_use_attn_result(False)\n",
    "gc.collect(); torch.cuda.empty_cache()\n",
    "print(f\"Resumed: V_refusal at L{BEST_LAYER}; top guardrail head = {guardrail_heads[0]}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "40767544",
