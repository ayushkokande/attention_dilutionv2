   "source": [
    "# --- Load Qwen3-1.7B via transformer_lens ---\n",
    "MODEL_NAME = 'Qwen/Qwen3-1.7B'\n",
    "MODEL_SLUG = 'qwen3-1.7b'\n",
    "\n",
    "model = HookedTransformer.from_pretrained_no_processing(\n",
    "    MODEL_NAME,\n",
    "    dtype=torch.bfloat16,\n",
    "    device=device,\n",
    "    default_padding_side='left',\n",
    "    n_ctx=32768,\n",
    ")\n",
    "model.eval()\n",
    "tokenizer = model.tokenizer\n",
    "print(f'n_layers={model.cfg.n_layers}  n_heads={model.cfg.n_heads}  d_model={model.cfg.d_model}  n_ctx={model.cfg.n_ctx}')\n",
    "# Expected: 28, 16, 2048, 32768 (or default 8192 — we'll override if needed)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "f2a3ca50",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "'<|im_start|>user\\nWhat is 2+2?<|im_end|>\\n<|im_start|>assistant\\n<think>\\n\\n</think>\\n\\n'\n"
     ]
    }
   ],
   "source": [
    "# --- Qwen3 chat template with THINKING DISABLED ---\n",
    "# This appends an empty <think></think> block so the model jumps straight to answering.\n",
    "def format_prompt(user_msg: str) -> str:\n",
    "    msgs = [{'role': 'user', 'content': user_msg}]\n",
    "    return tokenizer.apply_chat_template(\n",
    "        msgs,\n",
    "        tokenize=False,\n",
    "        add_generation_prompt=True,\n",
    "        enable_thinking=False,  # <<< critical for Qwen3\n",
    "    )\n",
    "\n",
    "# Sanity check — the formatted prompt should END with '<think>\\n\\n</think>\\n\\n'\n",
    "sample = format_prompt('What is 2+2?')\n",
    "print(repr(sample)[-300:])\n",
    "assert '<think>' in sample and '</think>' in sample, 'Qwen3 chat template missing empty think block — check transformers version'"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b2a96a1a",
   "metadata": {},
   "source": [
    "## Phase 1 — Find V_refusal and the Guardrail Heads\n",
    "\n",
    "**Method:** difference-of-means (Arditi et al. 2024). Faster, causally validated, and the refusal_direction reference implementation on GitHub uses this same approach.\n",
    "\n",
    "**Steps:**\n",
    "1. Score residual stream at the last instruction token for ~32 harmful + 32 harmless prompts.\n",
    "2. V_refusal^(l) = mean_harmful(h^l) - mean_harmless(h^l) for each layer l.\n",
    "3. Pick the best layer: the one whose direction, when ablated from all layers, most reduces refusal on held-out harmful prompts.\n",
    "4. For Guardrail Heads: direct logit attribution — each head's contribution to V_refusal at the chosen layer."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "81a20b2e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "train=32  val=18\n"
     ]
    }
   ],
   "source": [
    "# --- Minimal datasets. Small enough to keep Phase 1 under ~10 min on A100.\n",
