   ],
   "source": [
    "# --- Phase 6 figure B: per-source-token attention pattern of the TOP guardrail head,\n",
    "# at intact N_short vs intact N_long, with the harmful span shaded.\n",
    "\n",
    "top_l, top_h, top_v = guardrail_heads[0]\n",
    "print(f\"Top guardrail head: L{top_l:02d}H{top_h:02d}  ({top_v:+.4f})\")\n",
    "\n",
    "example = HARMFUL_EVAL[0]\n",
    "fig = make_subplots(rows=1, cols=2,\n",
    "    subplot_titles=[f\"L{top_l}H{top_h} pattern @ N={N_SHORT}\",\n",
    "                    f\"L{top_l}H{top_h} pattern @ N={N_LONG}\"])\n",
    "\n",
    "for idx, N in enumerate([N_SHORT, N_LONG]):\n",
    "    diluted, _ = build_diluted_prompt(example, N)\n",
    "    span, _ = locate_harmful_span(diluted, example)\n",
    "    pattern = per_source_token_attn_for_head(diluted, top_l, top_h, hooks_for_setting=None)\n",
    "    if pattern is None:\n",
    "        continue\n",
    "    seq = pattern.shape[0]\n",
    "    fig.add_trace(go.Bar(\n",
    "        x=list(range(seq)), y=pattern.tolist(),\n",
    "        name=f\"N={N}\", showlegend=(idx==0),\n",
    "        marker_color=\"#1f77b4\",\n",
    "    ), row=1, col=idx+1)\n",
    "    if span is not None:\n",
    "        s_lo, s_hi = span\n",
    "        fig.add_vrect(x0=s_lo-0.5, x1=s_hi-0.5, fillcolor=\"orange\", opacity=0.3,\n",
    "                      line_width=0, row=1, col=idx+1)\n",
    "    fig.update_xaxes(title=\"Source token index\", row=1, col=idx+1)\n",
    "    fig.update_yaxes(title=\"Attention weight (last token query)\", row=1, col=idx+1)\n",
    "\n",
    "fig.update_layout(\n",
    "    title=f\"Phase 6B: source-token attention of top guardrail head (orange = harmful span) — {MODEL_SLUG}\",\n",
    "    width=1300, height=520,\n",
    ")\n",
    "fig.write_image(str(OUT/\"fig_phase6_attribution_sourceflow.png\"), width=1300, height=520)\n",
    "fig.show()\n",
    "print(\"Saved: fig_phase6_attribution_sourceflow.png\")\n",
    "\n",
    "# Also dump a numeric summary: fraction of pattern mass on harmful span vs bloat,\n",
    "# for the top head, at short vs long N.\n",
    "summary_rows = []\n",
    "for N in [N_SHORT, N_LONG]:\n",
    "    fracs = []\n",
    "    for p in attr_subset:\n",
    "        diluted, _ = build_diluted_prompt(p, N)\n",
    "        span, _ = locate_harmful_span(diluted, p)\n",
    "        pattern = per_source_token_attn_for_head(diluted, top_l, top_h, hooks_for_setting=None)\n",
    "        if pattern is None or span is None:\n",
    "            continue\n",
    "        s_lo, s_hi = span\n",
    "        total = float(pattern.sum())\n",
    "        on_harm = float(pattern[s_lo:s_hi].sum())\n",
    "        fracs.append(on_harm / max(total, 1e-9))\n",
    "    if fracs:\n",
    "        summary_rows.append({\"head\": f\"L{top_l}H{top_h}\", \"N\": N,\n",
    "                             \"frac_attn_on_harmful_span_mean\": float(np.mean(fracs)),\n",
    "                             \"frac_attn_on_harmful_span_std\":  float(np.std(fracs)),\n",
    "                             \"n_prompts\": len(fracs)})\n",
    "pd.DataFrame(summary_rows).to_csv(OUT/\"phase6_top_head_attn_fraction.csv\", index=False)\n",
    "print(\"Saved: phase6_top_head_attn_fraction.csv\")\n"
   ]
  },
  {
