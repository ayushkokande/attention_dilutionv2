      "head attribution computed in 13.6s, shape=(25, 32)\n",
      "GUARDRAIL HEAD  L22H07  attribution=+3.7682\n",
      "GUARDRAIL HEAD  L22H04  attribution=+3.1087\n",
      "GUARDRAIL HEAD  L18H30  attribution=+2.1481\n",
      "GUARDRAIL HEAD  L22H05  attribution=+2.1154\n",
      "GUARDRAIL HEAD  L24H19  attribution=+1.5302\n",
      "GUARDRAIL HEAD  L23H02  attribution=+1.5073\n",
      "GUARDRAIL HEAD  L23H03  attribution=+1.2799\n",
      "GUARDRAIL HEAD  L22H19  attribution=+1.2474\n",
      "GUARDRAIL HEAD  L22H17  attribution=+1.2125\n",
      "GUARDRAIL HEAD  L18H29  attribution=+1.1679\n",
      "GUARDRAIL HEAD  L18H28  attribution=+1.0471\n",
      "GUARDRAIL HEAD  L21H15  attribution=+1.0447\n"
     ]
    }
   ],
   "source": [
    "# --- Identify Guardrail Heads via direct contribution to V_refusal at the last token.\n",
    "# Use a small subset (32 prompts) of HARMFUL_TRAIN for memory — set_use_attn_result is\n",
    "# very memory-hungry on 14B since it materializes [batch, seq, n_heads, d_model].\n",
    "\n",
    "GUARD_PROMPTS_N = 24  # set_use_attn_result is memory-hungry; 24 is safe on 40GB\n",
    "guard_subset = HARMFUL_TRAIN[:GUARD_PROMPTS_N]\n",
    "model.set_use_attn_result(True)\n",
    "\n",
    "def head_attributions_to_refusal(prompts, direction, read_layer):\n",
    "    n_heads = model.cfg.n_heads\n",
    "    totals = torch.zeros(read_layer + 1, n_heads, dtype=torch.float32)\n",
    "    direction_cpu = direction.float().cpu()\n",
    "    for p in tqdm(prompts, desc=\"head attribution\"):\n",
    "        text = format_prompt(p)\n",
    "        toks = model.to_tokens(text, prepend_bos=False)\n",
    "        if toks.shape[1] > model.cfg.n_ctx:\n",
    "            del toks; continue\n",
    "        _, cache = model.run_with_cache(\n",
    "            toks, names_filter=lambda n: n.endswith(\"attn.hook_result\"),\n",
    "        )\n",
    "        for l in range(read_layer + 1):\n",
    "            key = f\"blocks.{l}.attn.hook_result\"\n",
    "            per_head = cache[key][0, -1].float().cpu()  # [n_heads, d_model]\n",
    "            totals[l] += per_head @ direction_cpu\n",
    "        del cache, toks; gc.collect(); torch.cuda.empty_cache()\n",
    "    return totals / len(prompts)\n",
    "\n",
    "t0 = time.time()\n",
    "head_attrib = head_attributions_to_refusal(guard_subset, V_REFUSAL, BEST_LAYER)\n",
    "model.set_use_attn_result(False)\n",
    "gc.collect(); torch.cuda.empty_cache()\n",
    "print(f\"head attribution computed in {time.time()-t0:.1f}s, shape={tuple(head_attrib.shape)}\")\n",
    "\n",
    "flat = head_attrib.flatten()\n",
    "TOPK = 12\n",
    "top_vals, top_idx = torch.topk(flat, TOPK)\n",
    "guardrail_heads = []\n",
    "for v, i in zip(top_vals.tolist(), top_idx.tolist()):\n",
    "    l, h = i // head_attrib.shape[1], i % head_attrib.shape[1]\n",
    "    guardrail_heads.append((int(l), int(h), float(v)))\n",
    "    print(f\"GUARDRAIL HEAD  L{l:02d}H{h:02d}  attribution={v:+.4f}\")\n",
    "torch.save({\"head_attrib\": head_attrib, \"guardrail_heads\": guardrail_heads,\n",
    "            \"best_layer\": BEST_LAYER}, OUT/\"guardrail_heads.pt\")\n"
   ]
  },
