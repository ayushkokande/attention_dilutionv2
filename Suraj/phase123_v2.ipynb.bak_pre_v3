    }
   ],
   "source": [
    "df4 = pd.read_csv(OUT/\"phase4_capability.csv\").sort_values([\"setting\",\"N\"]).reset_index(drop=True)\n",
    "if \"status\" not in df4.columns: df4[\"status\"] = \"ok\"\n",
    "ok4 = df4[df4[\"status\"]==\"ok\"]; bad4 = df4[df4[\"status\"]!=\"ok\"]\n",
    "fig = go.Figure()\n",
    "color_map = {\"intact\":\"#1f77b4\",\"ablated\":\"#d62728\"}\n",
    "for setting in sorted(ok4[\"setting\"].unique()):\n",
    "    sub = ok4[ok4[\"setting\"]==setting].sort_values(\"N\")\n",
    "    x = sub[\"N\"].replace(0,1).tolist()\n",
    "    fig.add_trace(go.Scatter(x=x, y=sub[\"accuracy\"],\n",
    "                             name=f\"{setting}: accuracy\", mode=\"lines+markers\",\n",
    "                             line=dict(color=color_map.get(setting))))\n",
    "    fig.add_trace(go.Scatter(x=x, y=sub[\"refusal_on_benign\"],\n",
    "                             name=f\"{setting}: refusal\", mode=\"lines+markers\",\n",
    "                             yaxis=\"y2\", line=dict(color=color_map.get(setting), dash=\"dash\")))\n",
    "fig.update_layout(\n",
    "    title=f\"Phase 4: capability cost of V_refusal ({MODEL_SLUG})\",\n",
    "    xaxis=dict(title=\"N (log)\", type=\"log\"),\n",
    "    yaxis=dict(title=\"MMLU-mini acc\", range=[-0.08,1.05]),\n",
    "    yaxis2=dict(title=\"Refusal on benign\", overlaying=\"y\", side=\"right\", range=[-0.08,1.05]),\n",
    "    legend=dict(orientation=\"h\", y=-0.25), width=1000, height=560,\n",
    ")\n",
    "fig.write_image(str(OUT/\"fig_phase4_capability.png\"), width=1000, height=560)\n",
    "fig.show()\n"
   ]
  },
