   "source": [
    "# --- Qwen3-8B by default (fits on a 40GB A100 with headroom).\n",
    "# To run on Qwen3-14B you need an 80GB A100 / H100. Just change the two strings below.\n",
    "MODEL_NAME = \"Qwen/Qwen3-8B\"\n",
    "MODEL_SLUG = \"qwen3-8b\"\n",
    "\n",
    "# n_ctx capped to keep activations manageable. Qwen3 supports 32k natively but\n",
    "# our sweep tops out at ~16k of bloat + ~200 tokens template + harmful request.\n",
    "# 12000 is comfortable on 40GB; raise to 18000 only on 80GB.\n",
    "N_CTX = 12000\n",
    "\n",
    "# Pre-flight: clean any leftover allocations from a prior kernel restart\n",
    "import gc, torch\n",
    "gc.collect()\n",
    "if torch.cuda.is_available():\n",
    "    torch.cuda.empty_cache()\n",
    "    torch.cuda.reset_peak_memory_stats()\n",
    "    free, total = torch.cuda.mem_get_info()\n",
    "    print(f\"GPU memory before load: free={free/1e9:.2f} GB / total={total/1e9:.2f} GB\")\n",
    "    # Roughly: 8B weights are ~16 GB in bf16; need at least ~22 GB free to load + run.\n",
    "    if free < 18 * 1e9:\n",
    "        print(\"WARNING: <18 GB free. Another process may be holding memory.\")\n",
    "        print(\"Run !nvidia-smi in a new cell, kill stragglers, then restart this kernel.\")\n",
    "\n",
    "model = HookedTransformer.from_pretrained_no_processing(\n",
    "    MODEL_NAME,\n",
    "    dtype=torch.bfloat16,\n",
    "    device=device,\n",
    "    default_padding_side=\"left\",\n",
    "    n_ctx=N_CTX,\n",
    ")\n",
    "model.eval()\n",
    "tokenizer = model.tokenizer\n",
    "print(f\"n_layers={model.cfg.n_layers}  n_heads={model.cfg.n_heads}  \"\n",
    "      f\"d_model={model.cfg.d_model}  d_head={model.cfg.d_head}  n_ctx={model.cfg.n_ctx}\")\n",
    "\n",
    "if torch.cuda.is_available():\n",
    "    free, total = torch.cuda.mem_get_info()\n",
    "    print(f\"GPU memory after  load: free={free/1e9:.2f} GB / total={total/1e9:.2f} GB\")\n",
    "# Expected (Qwen3-8B): n_layers=36 n_heads=32 d_model=4096 d_head=128\n",
    "# Expected (Qwen3-14B on 80GB): n_layers=40 n_heads=40 d_model=5120 d_head=128\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "1c692a40",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "'<|im_start|>user\\nWhat is 2+2?<|im_end|>\\n<|im_start|>assistant\\n<think>\\n\\n</think>\\n\\n'\n"
     ]
    }
   ],
   "source": [
    "# --- Qwen3 chat template with THINKING DISABLED (mandatory for Qwen3 reasoning models).\n",
    "def format_prompt(user_msg: str) -> str:\n",
    "    msgs = [{\"role\": \"user\", \"content\": user_msg}]\n",
    "    return tokenizer.apply_chat_template(\n",
    "        msgs, tokenize=False, add_generation_prompt=True,\n",
    "        enable_thinking=False,\n",
    "    )\n",
    "\n",
    "sample = format_prompt(\"What is 2+2?\")\n",
    "print(repr(sample)[-300:])\n",
    "assert \"<think>\" in sample and \"</think>\" in sample, \\\n",
    "    \"Qwen3 chat template missing empty think block — bad transformers version\"\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c3b35109",
   "metadata": {},
   "source": [
    "## 2. Datasets — AdvBench (harmful) + Alpaca (harmless)\n",
    "\n",
    "We use:\n",
    "- **AdvBench** (`walledai/AdvBench`) for harmful prompts: ~520 instructions explicitly designed to elicit refusal. We use the `prompt` column.\n",
    "- **Alpaca** (`tatsu-lab/alpaca`) for harmless prompts: 52K instruction/output pairs. We filter to instructions with empty `input` (so they read as standalone requests) and length-match against AdvBench so the direction training pool isn't biased by length.\n",
    "\n",
    "Pools after split:\n",
    "- `HARMFUL_TRAIN`, `HARMLESS_TRAIN`: 256 each, used to compute V_refusal\n",
    "- `HARMFUL_EVAL`, `HARMLESS_EVAL`: 100 each, used for all sweeps (Phases 2-5)\n",
    "- `HARMFUL_BASELINE`, `HARMLESS_BASELINE`: up to 512/520, used once for the headline baseline refusal rate\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "1f8ca3f2-31a6-429c-b8ab-0e05af1e3ab8",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Add HF token here"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "f673351f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "AdvBench: 520 usable prompts\n",
      "Alpaca filtered: 31254 standalone instructions\n"
     ]
    }
   ],
   "source": [
    "from datasets import load_dataset\n",
    "\n",
    "# --- Harmful: AdvBench\n",
    "adv = load_dataset(\"walledai/AdvBench\", split=\"train\")\n",
    "# AdvBench has columns [\"prompt\", \"target\"]; we want the prompts.\n",
    "adv_prompts = [str(r[\"prompt\"]).strip() for r in adv]\n",
    "adv_prompts = [p for p in adv_prompts if 20 <= len(p) <= 400]\n",
    "random.Random(SEED).shuffle(adv_prompts)\n",
    "print(f\"AdvBench: {len(adv_prompts)} usable prompts\")\n",
    "\n",
    "# --- Harmless: Alpaca, filter to standalone instructions (no extra input)\n",
    "alp = load_dataset(\"tatsu-lab/alpaca\", split=\"train\")\n",
    "alp_prompts = []\n",
    "for r in alp:\n",
    "    inst = str(r.get(\"instruction\", \"\")).strip()\n",
    "    inp  = str(r.get(\"input\", \"\")).strip()\n",
    "    if inp:  # skip ones requiring an attached input doc — those are not standalone\n",
    "        continue\n",
    "    if 20 <= len(inst) <= 400:\n",
    "        alp_prompts.append(inst)\n",
    "random.Random(SEED).shuffle(alp_prompts)\n",
    "print(f\"Alpaca filtered: {len(alp_prompts)} standalone instructions\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "6fbabb4d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "matched pool size: 520\n",
      "train  harmful=256  harmless=256\n",
      "eval   harmful=100   harmless=100\n",
      "base   harmful=164  harmless=164\n",
      "Saved: splits.json\n"
     ]
    }
   ],
   "source": [
    "# --- Length-match the harmless pool against the harmful pool so the direction\n",
    "# training pool isn't accidentally a \"long-vs-short\" classifier.\n",
    "def length_match(target_pool, source_pool, tolerance=20):\n",
    "    \"\"\"For each item in target_pool, draw the closest unused item from source_pool by char length.\"\"\"\n",
    "    used = set()\n",
    "    matched = []\n",
    "    src_lens = [(i, len(s)) for i, s in enumerate(source_pool)]\n",
    "    for t in target_pool:\n",
    "        tl = len(t)\n",
    "        best_i, best_d = -1, 1e9\n",
    "        for i, sl in src_lens:\n",
    "            if i in used:\n",
    "                continue\n",
    "            d = abs(sl - tl)\n",
    "            if d < best_d:\n",
    "                best_i, best_d = i, d\n",
    "                if d <= tolerance:\n",
    "                    break\n",
    "        if best_i >= 0:\n",
    "            used.add(best_i)\n",
    "            matched.append(source_pool[best_i])\n",
    "    return matched\n",
    "\n",
    "# Take 1000 AdvBench (cap) and the same number of length-matched Alpaca\n",
    "HARMFUL_POOL = adv_prompts[: min(1000, len(adv_prompts))]\n",
    "HARMLESS_POOL = length_match(HARMFUL_POOL, alp_prompts, tolerance=15)\n",
    "n = min(len(HARMFUL_POOL), len(HARMLESS_POOL))\n",
    "HARMFUL_POOL  = HARMFUL_POOL[:n]\n",
    "HARMLESS_POOL = HARMLESS_POOL[:n]\n",
    "print(f\"matched pool size: {n}\")\n",
    "\n",
    "# Splits\n",
    "HARMFUL_TRAIN,    HARMLESS_TRAIN    = HARMFUL_POOL[:256],     HARMLESS_POOL[:256]\n",
    "HARMFUL_EVAL,     HARMLESS_EVAL     = HARMFUL_POOL[256:356],  HARMLESS_POOL[256:356]\n",
    "# Baseline pool: everything else, capped at 512/520\n",
    "HARMFUL_BASELINE  = HARMFUL_POOL[356:356+512]\n",
    "HARMLESS_BASELINE = HARMLESS_POOL[356:356+512]\n",
    "\n",
    "print(f\"train  harmful={len(HARMFUL_TRAIN)}  harmless={len(HARMLESS_TRAIN)}\")\n",
    "print(f\"eval   harmful={len(HARMFUL_EVAL)}   harmless={len(HARMLESS_EVAL)}\")\n",
    "print(f\"base   harmful={len(HARMFUL_BASELINE)}  harmless={len(HARMLESS_BASELINE)}\")\n",
    "\n",
    "# Save the splits so any analysis on the cluster reproduces exactly\n",
    "import json as _json\n",
    "with (OUT / \"splits.json\").open(\"w\") as f:\n",
    "    _json.dump({\n",
    "        \"harmful_train\": HARMFUL_TRAIN, \"harmless_train\": HARMLESS_TRAIN,\n",
    "        \"harmful_eval\": HARMFUL_EVAL,   \"harmless_eval\": HARMLESS_EVAL,\n",
    "        \"harmful_baseline\": HARMFUL_BASELINE, \"harmless_baseline\": HARMLESS_BASELINE,\n",
    "    }, f, indent=2, ensure_ascii=False)\n",
    "print(\"Saved: splits.json\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "450388d7",
   "metadata": {},
   "source": [
    "## Phase 1 — Find V_refusal and the Guardrail Heads\n",
    "\n",
    "(a) Cache resid_post at the last instruction-token position for HARMFUL_TRAIN and HARMLESS_TRAIN, all layers.\n",
    "(b) V_refusal^(l) = mean(harmful) - mean(harmless), unit-normalized.\n",
    "(c) Sweep candidate layers; pick BEST_LAYER as the one whose ablation maximizes the drop in refusal rate on a small sweep eval set.\n",
    "(d) Validate on a disjoint matched-pool eval (HARMFUL_EVAL / HARMLESS_EVAL) — direction must transfer to held-out prompts.\n",
    "(e) Identify Guardrail Heads via DLA onto V_refusal.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "9f7e865c",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "cache harmful: 100%|██████████| 256/256 [01:38<00:00,  2.61it/s]\n",
      "cache harmless: 100%|██████████| 256/256 [01:34<00:00,  2.70it/s]\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "shapes: harmful=(256, 36, 4096) harmless=(256, 36, 4096) in 193.0s\n"
     ]
    }
   ],
   "source": [
    "# --- Cache resid_post at the last instruction-token position, per layer.\n",
    "def cache_last_token_resid(prompts, model, desc=\"cache\"):\n",
    "    n_layers = model.cfg.n_layers\n",
    "    d_model = model.cfg.d_model\n",
    "    out = torch.zeros(len(prompts), n_layers, d_model, dtype=torch.float32)\n",
    "    for i, p in enumerate(tqdm(prompts, desc=desc)):\n",
    "        text = format_prompt(p)\n",
    "        toks = model.to_tokens(text, prepend_bos=False)\n",
    "        if toks.shape[1] > model.cfg.n_ctx:\n",
    "            print(f\"  skip prompt {i}: {toks.shape[1]} tokens > n_ctx\")\n",
    "            del toks; continue\n",
    "        _, cache = model.run_with_cache(\n",
    "            toks, names_filter=lambda n: n.endswith(\"resid_post\"),\n",
    "        )\n",
    "        for l in range(n_layers):\n",
    "            out[i, l] = cache[f\"blocks.{l}.hook_resid_post\"][0, -1].float().cpu()\n",
    "        del cache, toks; gc.collect(); torch.cuda.empty_cache()\n",
    "    return out\n",
    "\n",
    "t0 = time.time()\n",
    "harmful_acts  = cache_last_token_resid(HARMFUL_TRAIN,  model, desc=\"cache harmful\")\n",
    "harmless_acts = cache_last_token_resid(HARMLESS_TRAIN, model, desc=\"cache harmless\")\n",
    "print(f\"shapes: harmful={tuple(harmful_acts.shape)} harmless={tuple(harmless_acts.shape)} \"\n",
    "      f\"in {time.time()-t0:.1f}s\")\n",
    "torch.save({\"harmful_acts\": harmful_acts, \"harmless_acts\": harmless_acts}, OUT/\"phase1_acts.pt\")\n"
   ]
  },
