   "source": [
    "# --- Phase 2 main loop: TWO-PASS, per-N OOM-tolerant.\n",
    "guard_layers = sorted({l for (l,_,_) in guardrail_heads})\n",
    "guard_pairs  = [(l,h) for (l,h,_) in guardrail_heads]\n",
    "MAX_ATTN_N = 2048   # full attention pattern OOMs above this on 40GB; use 4096 on 80GB\n",
    "\n",
    "p2_csv = OUT / \"phase2_scaling.csv\"\n",
    "FORCE_REDO = False\n",
    "if p2_csv.exists() and not FORCE_REDO:\n",
    "    df_existing = pd.read_csv(p2_csv)\n",
    "    if \"status\" not in df_existing.columns: df_existing[\"status\"] = \"ok\"\n",
    "    done_Ns = set(df_existing.loc[df_existing[\"status\"]==\"ok\",\"N\"].tolist())\n",
    "    p2_records = df_existing.to_dict(\"records\")\n",
    "    print(f\"Resuming. Done Ns: {sorted(done_Ns)}\")\n",
    "else:\n",
    "    done_Ns = set(); p2_records = []\n",
    "\n",
    "todo_Ns = [N for N in CONTEXT_LENGTHS if N not in done_Ns]\n",
    "print(f\"Sweeping N: {todo_Ns}\")\n",
    "\n",
    "\n",
    "def measure_one_prompt(p, N, measure_attn):\n",
    "    diluted_msg, _ = build_diluted_prompt(p, N)\n",
    "    span, _ = locate_harmful_span(diluted_msg, p)\n",
    "    text = format_prompt(diluted_msg)\n",
    "    toks = model.to_tokens(text, prepend_bos=False)\n",
    "    if toks.shape[1] > model.cfg.n_ctx or span is None:\n",
    "        del toks; return None, None\n",
    "    s_lo, s_hi = span\n",
    "\n",
    "    captured_attn = {}\n",
    "    captured_resid = [None]\n",
    "    def make_attn_hook(layer):\n",
    "        heads_for_layer = [h for (ll,h) in guard_pairs if ll==layer]\n",
    "        def fn(pattern, hook):\n",
    "            for h in heads_for_layer:\n",
    "                captured_attn[(layer,h)] = pattern[0, h, -1, s_lo:s_hi].float().sum().item()\n",
    "            return None\n",
    "        return fn\n",
    "    def resid_hook(resid, hook):\n",
    "        captured_resid[0] = resid[0, s_hi-1].float().cpu().clone()\n",
    "        return None\n",
    "\n",
    "    fwd_hooks = []\n",
    "    if measure_attn:\n",
    "        fwd_hooks = [(f\"blocks.{l}.attn.hook_pattern\", make_attn_hook(l)) for l in guard_layers]\n",
    "    fwd_hooks.append((f\"blocks.{BEST_LAYER}.hook_resid_post\", resid_hook))\n",
    "\n",
    "    try:\n",
    "        with model.hooks(fwd_hooks=fwd_hooks):\n",
    "            _ = model(toks)\n",
    "    finally:\n",
    "        model.reset_hooks(); del toks, fwd_hooks\n",
    "\n",
    "    attn_mass = float(np.mean(list(captured_attn.values()))) if captured_attn else None\n",
    "    cos = None\n",
    "    if captured_resid[0] is not None:\n",
    "        cos = torch.nn.functional.cosine_similarity(\n",
    "            captured_resid[0].unsqueeze(0), V_REFUSAL.unsqueeze(0)).item()\n",
    "    del captured_attn, captured_resid\n",
    "    return attn_mass, cos\n",
    "\n",
    "\n",
    "def save_p2():\n",
    "    pd.DataFrame(p2_records).sort_values(\"N\").to_csv(p2_csv, index=False)\n",
    "\n",
    "\n",
    "for N in todo_Ns:\n",
    "    print(f\"\\n=== N={N} ===\")\n",
    "    measure_attn = (N <= MAX_ATTN_N)\n",
    "    if not measure_attn:\n",
    "        print(f\"  H1 disabled at N={N}. H2+behavior only.\")\n",
    "\n",
    "    attn_all, cos_all, refusals = [], [], 0\n",
    "    n_meas, n_gen = 0, 0\n",
    "    status, error_msg = \"ok\", \"\"\n",
    "\n",
    "    try:\n",
    "        # Pass A: measurement\n",
    "        for p in tqdm(HARMFUL_EVAL, desc=f\"meas N={N}\"):\n",
    "            try:\n",
    "                a, c = measure_one_prompt(p, N, measure_attn)\n",
    "            except torch.cuda.OutOfMemoryError as e:\n",
    "                print(f\"  OOM at N={N}: {e}\")\n",
    "                model.reset_hooks(); gc.collect(); torch.cuda.empty_cache()\n",
    "                status, error_msg = \"OOM_measure\", \"OOM in pass A\"\n",
    "                raise\n",
    "            if a is not None: attn_all.append(a)\n",
    "            if c is not None: cos_all.append(c); n_meas += 1\n",
    "            gc.collect(); torch.cuda.empty_cache()\n",
    "        model.reset_hooks(); gc.collect(); torch.cuda.empty_cache()\n",
    "\n",
    "        # Pass B: behavior\n",
    "        for p in tqdm(HARMFUL_EVAL, desc=f\"gen  N={N}\"):\n",
    "            diluted_msg, _ = build_diluted_prompt(p, N)\n",
    "            text = format_prompt(diluted_msg)\n",
    "            toks_check = model.to_tokens(text, prepend_bos=False)\n",
    "            too_long = toks_check.shape[1] > model.cfg.n_ctx\n",
    "            del toks_check\n",
    "            if too_long: continue\n",
    "            try:\n",
    "                g = generate(model, diluted_msg, max_new_tokens=24)\n",
    "            except torch.cuda.OutOfMemoryError:\n",
    "                torch.cuda.empty_cache(); gc.collect(); continue\n",
    "            n_gen += 1\n",
    "            if is_refusal(g): refusals += 1\n",
    "            torch.cuda.empty_cache()\n",
    "\n",
    "    except torch.cuda.OutOfMemoryError:\n",
    "        pass\n",
    "    except Exception as e:\n",
    "        status, error_msg = \"error\", repr(e)[:200]\n",
    "        print(f\"  non-OOM error at N={N}: {error_msg}\")\n",
    "    finally:\n",
    "        model.reset_hooks(); gc.collect(); torch.cuda.empty_cache()\n",
    "\n",
    "    rec = {\n",
    "        \"N\": N,\n",
    "        \"attn_to_harmful\":     float(np.mean(attn_all)) if attn_all else float(\"nan\"),\n",
    "        \"attn_to_harmful_std\": float(np.std (attn_all)) if attn_all else float(\"nan\"),\n",
    "        \"cos_refusal\":         float(np.mean(cos_all))  if cos_all  else float(\"nan\"),\n",
    "        \"cos_refusal_std\":     float(np.std (cos_all))  if cos_all  else float(\"nan\"),\n",
    "        \"refusal_rate\":        (refusals/n_gen) if n_gen>0 else float(\"nan\"),\n",
    "        \"n_evaluated\":         n_gen, \"status\": status, \"error_msg\": error_msg,\n",
    "    }\n",
    "    p2_records = [r for r in p2_records if r.get(\"N\") != N]\n",
    "    p2_records.append(rec); save_p2()\n",
    "    print(f\"  N={N}  status={status}  attn={rec['attn_to_harmful']:.4f}  \"\n",
    "          f\"cos={rec['cos_refusal']:.4f}  refusal={rec['refusal_rate']:.2%}  \"\n",
    "          f\"(n_meas={n_meas}, n_gen={n_gen})\")\n",
    "\n",
    "df2 = pd.read_csv(p2_csv).sort_values(\"N\").reset_index(drop=True)\n",
    "df2\n"
   ]
  },
