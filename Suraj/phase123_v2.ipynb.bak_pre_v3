      "ablated/harmless N=4096:  59%|█████▉    | 59/100 [09:04<06:17,  9.21s/it]"
     ]
    }
   ],
   "source": [
    "PHASE5_NS = [0, 128, 512, 1024, 2048, 4096]\n",
    "PHASE5_SETTINGS = [\"intact\",\"ablated\"]\n",
    "PHASE5_PT = {\"harmful\": HARMFUL_EVAL, \"harmless\": HARMLESS_EVAL}\n",
    "\n",
    "p5_csv = OUT / \"phase5_refusal_2x2.csv\"\n",
    "FORCE_REDO_PHASE5 = False\n",
    "if p5_csv.exists() and not FORCE_REDO_PHASE5:\n",
    "    df_existing5 = pd.read_csv(p5_csv)\n",
    "    if \"status\" not in df_existing5.columns: df_existing5[\"status\"] = \"ok\"\n",
    "    done5 = {(str(r.setting), str(r.prompt_type), int(r.N)) for r in df_existing5.itertuples() if r.status==\"ok\"}\n",
    "    p5_records = df_existing5.to_dict(\"records\")\n",
    "else:\n",
    "    done5 = set(); p5_records = []\n",
    "\n",
    "\n",
    "def save_p5():\n",
    "    pd.DataFrame(p5_records).sort_values([\"setting\",\"prompt_type\",\"N\"]).to_csv(p5_csv, index=False)\n",
    "\n",
    "\n",
    "ablation_hooks_p5 = make_ablation_hooks(V_REFUSAL, model.cfg.n_layers)\n",
    "for setting in PHASE5_SETTINGS:\n",
    "    hooks_for_setting = ablation_hooks_p5 if setting==\"ablated\" else None\n",
    "    print(f\"\\n=== {setting} ===\")\n",
    "    for prompt_type, prompts in PHASE5_PT.items():\n",
    "        print(f\"  -- {prompt_type} (n={len(prompts)}) --\")\n",
    "        for N in PHASE5_NS:\n",
    "            if (setting, prompt_type, N) in done5: continue\n",
    "            refusals, n_done = 0, 0\n",
    "            status, error_msg = \"ok\", \"\"\n",
    "            try:\n",
    "                for p in tqdm(prompts, desc=f\"{setting}/{prompt_type} N={N}\"):\n",
    "                    diluted, _ = build_diluted_prompt(p, N)\n",
    "                    text = format_prompt(diluted)\n",
    "                    toks_check = model.to_tokens(text, prepend_bos=False)\n",
    "                    too_long = toks_check.shape[1] > model.cfg.n_ctx\n",
    "                    del toks_check\n",
    "                    if too_long: continue\n",
    "                    try:\n",
    "                        g = generate(model, diluted, hooks=hooks_for_setting, max_new_tokens=24)\n",
    "                    except torch.cuda.OutOfMemoryError:\n",
    "                        model.reset_hooks(); gc.collect(); torch.cuda.empty_cache(); raise\n",
    "                    n_done += 1\n",
    "                    if is_refusal(g): refusals += 1\n",
    "                    model.reset_hooks(); torch.cuda.empty_cache()\n",
    "            except torch.cuda.OutOfMemoryError as e:\n",
    "                status, error_msg = \"OOM\", repr(e)[:200]\n",
    "            except Exception as e:\n",
    "                status, error_msg = \"error\", repr(e)[:200]\n",
    "            finally:\n",
    "                model.reset_hooks(); gc.collect(); torch.cuda.empty_cache()\n",
    "            rec = {\"setting\":setting, \"prompt_type\":prompt_type, \"N\":N,\n",
    "                   \"refusal_rate\": refusals/n_done if n_done>0 else float(\"nan\"),\n",
    "                   \"n_evaluated\": n_done, \"status\": status, \"error_msg\": error_msg}\n",
    "            p5_records = [r for r in p5_records\n",
    "                          if not (str(r.get(\"setting\"))==setting\n",
    "                                  and str(r.get(\"prompt_type\"))==prompt_type\n",
    "                                  and int(r.get(\"N\",-1))==N)]\n",
    "            p5_records.append(rec); save_p5()\n",
    "            print(f\"    {setting:>7s} {prompt_type:>8s} N={N:>5}  refusal={rec['refusal_rate']:.2%}  status={status}\")\n"
   ]
  },
