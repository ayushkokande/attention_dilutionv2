   ],
   "source": [
    "# --- Phase 6 figure A: 2x2 panel of (layer x head) DLA heatmaps.\n",
    "fig = make_subplots(rows=2, cols=2,\n",
    "    subplot_titles=[\n",
    "        f\"intact, N={N_SHORT}\",   f\"intact, N={N_LONG}\",\n",
    "        f\"ablated, N={N_SHORT}\",  f\"ablated, N={N_LONG}\",\n",
    "    ])\n",
    "panel_coords = {(\"intact\",  N_SHORT):(1,1), (\"intact\",  N_LONG):(1,2),\n",
    "                (\"ablated\", N_SHORT):(2,1), (\"ablated\", N_LONG):(2,2)}\n",
    "\n",
    "# Pick a single shared color range so panels are directly comparable\n",
    "all_vals = []\n",
    "for v in attribution_maps.values():\n",
    "    if v is not None: all_vals.append(v.numpy())\n",
    "if all_vals:\n",
    "    cmax = float(np.max(np.abs(np.concatenate([x.flatten() for x in all_vals]))))\n",
    "else:\n",
    "    cmax = 1.0\n",
    "\n",
    "for (setting, N), heat in attribution_maps.items():\n",
    "    if heat is None: continue\n",
    "    r, c = panel_coords[(setting, N)]\n",
    "    fig.add_trace(go.Heatmap(\n",
    "        z=heat.numpy(), zmin=-cmax, zmax=cmax, colorscale=\"RdBu_r\",\n",
    "        colorbar=dict(title=\"DLA -> V_refusal\") if (r==1 and c==2) else None,\n",
    "        showscale=(r==1 and c==2),\n",
    "    ), row=r, col=c)\n",
    "    fig.update_xaxes(title=\"Head\", row=r, col=c)\n",
    "    fig.update_yaxes(title=\"Layer\", row=r, col=c, autorange=\"reversed\")\n",
    "\n",
    "fig.update_layout(\n",
    "    title=f\"Phase 6: attribution maps (per-head DLA onto V_refusal) — {MODEL_SLUG}\",\n",
    "    width=1300, height=900,\n",
    ")\n",
    "fig.write_image(str(OUT/\"fig_phase6_attribution_maps.png\"), width=1300, height=900)\n",
    "fig.show()\n",
    "print(\"Saved: fig_phase6_attribution_maps.png\")\n",
    "\n",
    "\n",
    "# Print the top-5 head deltas (intact N_long vs intact N_short) — these are the\n",
    "# heads that \"turn off\" most as bloat grows.\n",
    "intact_short = attribution_maps.get((\"intact\", N_SHORT))\n",
    "intact_long  = attribution_maps.get((\"intact\", N_LONG))\n",
    "if intact_short is not None and intact_long is not None:\n",
    "    delta = (intact_short - intact_long).numpy()\n",
    "    flat = delta.flatten()\n",
    "    idx = np.argsort(-flat)[:8]\n",
    "    print(\"\\nTop 8 heads losing most DLA from N=0 -> N=long (these are bloat-fragile guardrails):\")\n",
    "    for i in idx:\n",
    "        l, h = i // delta.shape[1], i % delta.shape[1]\n",
    "        print(f\"  L{int(l):02d}H{int(h):02d}  delta={float(flat[i]):+.4f}  \"\n",
    "              f\"(short={float(intact_short[l,h]):+.4f}, long={float(intact_long[l,h]):+.4f})\")\n"
   ]
  },
