   "source": [
    "# --- V_refusal per layer (unit-normalized) and norm plot.\n",
    "V_refusal_per_layer = harmful_acts.mean(0) - harmless_acts.mean(0)   # [n_layers, d_model]\n",
    "V_refusal_norms = V_refusal_per_layer.norm(dim=-1)\n",
    "V_refusal_unit  = V_refusal_per_layer / V_refusal_norms.unsqueeze(-1).clamp_min(1e-8)\n",
    "\n",
    "fig = px.line(\n",
    "    x=list(range(len(V_refusal_norms))), y=V_refusal_norms.tolist(),\n",
    "    labels={\"x\": \"Layer\", \"y\": \"||V_refusal||\"},\n",
    "    title=f\"Norm of V_refusal per layer ({MODEL_SLUG})\",\n",
    ")\n",
    "fig.write_image(str(OUT/\"fig_phase1_norms.png\"), width=900, height=420)\n",
    "fig.show()\n",
    "print(f\"peak layer (by norm): {int(V_refusal_norms.argmax())}  \"\n",
    "      f\"({V_refusal_norms.max():.2f}) — Arditi-style direction usually peaks ~50-70% depth\")\n"
   ]
  },
