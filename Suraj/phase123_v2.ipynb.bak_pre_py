    "    yaxis=dict(title=\"Refusal rate\", range=[-0.05,1.05]),\n",
    "    legend=dict(orientation=\"h\", y=-0.25), width=950, height=520,\n",
    ")\n",
    "fig.write_image(str(OUT/f\"fig_phase3_rescue_{FOCAL_FORMAT}.png\"), width=950, height=520)\n",
    "fig.show()\n"
   ]
